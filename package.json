{
  "name": "mineconnect-web",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev": "vite",
    "start": "node scripts/serve.js",
    "build": "vite build",
    "build:dist": "bash scripts/build-dist.sh",
    "verify": "bash scripts/verify-security.sh",
    "verify:prod": "URL=https://www.mineconnect.com.ar bash scripts/verify-security.sh",
    "csp:hashes": "bash scripts/compute-csp-hashes.sh site | sort -u",
    "csp:check": "bash -c 'diff <(bash scripts/compute-csp-hashes.sh site | sort -u) <(grep -oE \"\\x27sha256-[A-Za-z0-9+/=]+\\x27\" site/_headers | sort -u)'",
    "cf:setup": "bash scripts/cloudflare-setup.sh",
    "audit": "npm audit --audit-level=high",
    "audit:fix": "npm audit fix",
    "test": "bash scripts/verify-security.sh"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "leaflet": "^1.9.4",
    "lucide": "^1.16.0",
    "lucide-static": "^1.16.0",
    "vite": "^8.0.14"
  }
}