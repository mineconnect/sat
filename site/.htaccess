# MineConnect — fallback Apache (cPanel / shared hosting)
# Solo se usa si el sitio termina en Apache. En Cloudflare/Netlify/Vercel se ignora.

Options -Indexes -MultiViews
ServerSignature Off

# Forzar HTTPS
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} !=on
  RewriteCond %{HTTP:X-Forwarded-Proto} !https
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]
</IfModule>

# Headers de seguridad
<IfModule mod_headers.c>
  Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "DENY"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=(), interest-cohort=()"
  Header always set Cross-Origin-Opener-Policy "same-origin"
  Header always set Cross-Origin-Resource-Policy "same-origin"
  Header always set X-Permitted-Cross-Domain-Policies "none"
  Header always set Reporting-Endpoints "csp-endpoint=\"https://mgeukotlgrjyauwgdjxv.supabase.co/functions/v1/csp-report\", default=\"https://mgeukotlgrjyauwgdjxv.supabase.co/functions/v1/csp-report\""
  Header always set Report-To "{\"group\":\"csp-endpoint\",\"max_age\":10886400,\"endpoints\":[{\"url\":\"https://mgeukotlgrjyauwgdjxv.supabase.co/functions/v1/csp-report\"}],\"include_subdomains\":true}"
  Header always set NEL "{\"report_to\":\"csp-endpoint\",\"max_age\":10886400,\"include_subdomains\":true,\"success_fraction\":0.0,\"failure_fraction\":0.1}"
  Header always set Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self' https://wa.me; img-src 'self' data: https:; font-src 'self' https://fonts.gstatic.com data:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; script-src 'self' 'sha256-FCEC/e6u8jcKeyqinPN9rd79CnJ8jGywn/1c1JBPEms=' 'sha256-HvNReFJYVFaqTXRNXLhKrY4TsuQnQIo7oltL30I8Ybg=' 'sha256-JAuK4qdSar7kxco//W5pwjbL2935mvoSHN5hrvX9ac0=' 'sha256-Lmp5t6cgT2bkBRtwHRm4JuIR+w3g8IK8rpwlo1DpZS4=' 'sha256-TW79Rfn35DN8UTo3AgOg28Enfqg3CH3CtSEaJ++IIiU=' 'sha256-Wr8m4Vl+W2YiJf0mh+KnVadXefHV3lm8hroT1uWNf74=' 'sha256-YDjSAOd1NBk0ki7aVU3SNLV+V6T3z1MCFfNPATvMO9A=' 'sha256-YZVQefd2CiXS6wrLHihT9fmHJNTaD2sydOsTQAx/WB4=' 'sha256-YpQST9r+zEWGxmrsg+TxXczLABN0Tohx1Wzcl1zpjhg=' 'sha256-aA1JpZOoX39jPO1KkFp1dk1kT3NY0+NvqEDhlP6DugM=' 'sha256-hrRvUuFKG2aKJwr7yyf/lv8MCgQ3i1azzb0fP5CAhcg=' 'sha256-kdGfLp4XT9/zyXBet0R7mMV3owxpnj962K3mnj4IqaI=' 'sha256-rbtPIfZJMjAtMtGWB0KVgo6uPCjMgoMJvRojp1uzd/4=' 'sha256-tX3COENIQtluG25rR1DBmmUsxNMVPBODFQCPWnvOOg4=' 'sha256-tpuBWT5bj7cVOhK5V/YnP5r2a9HEnYOuDKD7pzZbHM8='; connect-src 'self' https://mineconnect-chat-api.vercel.app https://*.supabase.co https://*.supabase.in wss://*.supabase.co; manifest-src 'self'; worker-src 'self'; upgrade-insecure-requests; report-uri https://mgeukotlgrjyauwgdjxv.supabase.co/functions/v1/csp-report"
  Header unset X-Powered-By
  Header unset Server
</IfModule>

# Bloquear archivos sensibles
<FilesMatch "(^\.|\.env|\.git|\.log|composer\.|package\.json|package-lock\.json|node_modules)">
  Require all denied
</FilesMatch>

# Bloquear acceso al directorio .git si existiera
RedirectMatch 404 /\.git
RedirectMatch 404 /node_modules
RedirectMatch 404 /\.env

# MIME types correctos para SVG y webp
<IfModule mod_mime.c>
  AddType image/svg+xml .svg
  AddType image/webp .webp
</IfModule>

# Cache de assets
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/png            "access plus 1 year"
  ExpiresByType image/webp           "access plus 1 year"
  ExpiresByType image/svg+xml        "access plus 1 month"
  ExpiresByType text/css             "access plus 7 days"
  ExpiresByType application/javascript "access plus 7 days"
  ExpiresByType text/html            "access plus 5 minutes"
</IfModule>
